{% set asset = block.asset is defined and block.asset ? block.asset.one() : null %}
{% set assetMobile = block.assetMobile is defined and block.assetMobile ? block.assetMobile.one() : null %}
{% set displayWidth = block.displayWidth is defined ? block.displayWidth : false %}
{% set overlapSections = block.overlapSections is defined ? block.overlapSections : false %}
{% set loopVideo = block.loopVideo is defined ? block.loopVideo : true %}
{% set displayWidthValue = displayWidth.value ?? displayWidth %}
{% set isViewportWidth = displayWidthValue == true or displayWidthValue == 'viewport' %}
{% set outerClass = isViewportWidth ? 'w-full' : 'page' %}
{% set sectionClass = [
	'media-section',
	'relative',
	'overflow-hidden',
	'w-full',
	'h-[400px] md:h-[600px] lg:h-[800px]',
	overlapSections ? '!-my-24 lg:!-my-40 -z-1' : 'rounded-xl'
]|join(' ') %}

{% if asset %}
	<div class="{{ outerClass }}">
		<div class="{{ sectionClass }}">
			{% if overlapSections %}
				{% include '_includes/_blocks/gradient' with {
					variant: 'band',
					height: '1/3',
					colorOpacity: 100,
					fromColor: 'white',
					class: 'bottom-0'
				} %}
				{% include '_includes/_blocks/gradient' with {
					variant: 'band',
					height: '1/3',
					colorOpacity: 100,
					fromColor: 'white',
					class: 'top-0',
					direction: 'b'
				} %}
			{% endif %}

			{% include '_includes/_blocks/asset' with {
				asset: asset,
				assetMobile: assetMobile,
				class: 'home-middle-video__asset h-full w-full z-0',
				autoplay: true,
				loopVideo: loopVideo,
				videoLqip: false
			} %}
		</div>
	</div>
{% endif %}
