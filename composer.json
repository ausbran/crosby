{
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "craftcms/ckeditor": "^5.4.0",
    "craftcms/cms": "^5.9.20",
    "craftsnippets/craft-image-toolbox": "3.0.1",
    "deuxhuithuit/craft-cloudflare-stream": "^2.3",
    "nystudio107/craft-retour": "^5.0.14",
    "nystudio107/craft-seomatic": "^5.1.21",
    "vaersaagod/dospaces": "3.2.1",
    "verbb/field-manager": "4.0.3",
    "verbb/formie": "^3.1.20",
    "vlucas/phpdotenv": "^5.6.3"
  },
  "require-dev": {
    "craftcms/generator": "^2.2",
    "yiisoft/yii2-shell": "^2.0.3"
  },
  "autoload": {
    "psr-4": {
      "modules\\": "modules/"
    }
  },
  "config": {
    "allow-plugins": {
      "craftcms/plugin-installer": true,
      "yiisoft/yii2-composer": true
    },
    "sort-packages": true,
    "optimize-autoloader": true,
    "platform": {
      "php": "8.2"
    }
  },
  "scripts": {
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example.dev', '.env');\""
    ]
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://composer.craftcms.com",
      "canonical": false
    }
  ]
}
