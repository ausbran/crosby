{% extends "index" %}

{% set socialAsset = null %}
{% if entry.asset|length %}
	{% for heroAsset in entry.asset.all() %}
		{% if not socialAsset and heroAsset.kind == 'image' %}
			{% set socialAsset = heroAsset %}
		{% endif %}
	{% endfor %}
{% endif %}
{% if not socialAsset and entry.middleAsset|length %}
	{% set socialAsset = entry.middleAsset.one() %}
{% endif %}
{% if socialAsset and seomatic is defined %}
	{% if socialAsset.kind == 'image' %}
		{% set socialImageUrl = socialAsset.getUrl({
			width: 1200,
			height: 630,
			mode: 'crop',
			format: 'jpg',
			quality: 90
		}) ?: socialAsset.url %}
		{% do seomatic.meta.seoImage(socialImageUrl) %}
		{% do seomatic.meta.seoImageWidth(1200) %}
		{% do seomatic.meta.seoImageHeight(630) %}
	{% elseif socialAsset.kind == 'video' %}
		{% set videoStreamField = craft.app.fields.getFieldByHandle('videoStream') %}
		{% set streamValue = videoStreamField ? socialAsset.getFieldValue('videoStream') : null %}
		{% if streamValue and streamValue.thumbnail is defined and streamValue.thumbnail %}
			{% do seomatic.meta.seoImage(streamValue.thumbnail) %}
		{% endif %}
	{% endif %}
{% endif %}

{% block content %}
	{# first banner #}
	{% if (entry.heroSlides is defined and entry.heroSlides|length) or entry.asset|length %}
		{% include '_includes/_blocks/bannerHero' with {
            block: entry
        } %}
	{% endif %}

	{# first slider #}
	{% include '_includes/_blocks/sliderFixed' with {
		block: entry,
		showHeader: false
	} %}

	{# video between sliders #}
	<div class="home-middle-video w-full h-[400px] md:h-[600px] lg:h-[800px] !-my-24 lg:!-my-40 -z-1 overflow-hidden relative">
		{% include '_includes/_blocks/gradient' with {
            height: '1/3',
            opacity: 100,
            fromColor: 'white',
            class: 'bottom-0'
        } %}
		{% include '_includes/_blocks/gradient' with {
            height: '1/3',
            opacity: 100,
            fromColor: 'white',
            class: 'top-0',
            direction: 'b'
        } %}
		{% include '_includes/_blocks/asset' with {
            asset: entry.middleAsset.one(),
            class: 'home-middle-video__asset h-full w-full z-0',
            autoplay: true,
            videoLqip: false
        } %}
	</div>


	{# second slider #}
	<div class="page grid grid-cols-4 md:grid-cols-6 lg:grid-cols-8 xl:grid-cols-12 fade-in" data-cascade>
		{% include '_includes/_blocks/slider' with { 
			slides: entry.slidesLand.all(),
			header: entry.sliderHeader2,
			sliderWrapperClass: 'col-span-12 grid grid-cols-subgrid',
			sliderClass: 'col-span-12 h-[400px] md:h-[500px] lg:h-[600px] max-md:w-screen',
			arrows: false,
			arrowsClass: '!m-0'
		} %}
	</div>

	{# second banner #}
	{% if entry.textBottom|length %}
		{% include '_includes/_blocks/bannerSlides' with {
            block: entry,
            assets: entry.assetBottom.all(),
            text: entry.textBottom,
			buttons: entry.buttonsBottom.all(),
			bannerBody: true
        } %}
	{% endif %}

{% endblock %}
