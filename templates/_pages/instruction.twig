{% extends "index" %}
{% set bodyClass = 'bg-texture' %}

{% block content %}
	{% set steps = entry.instructionBlocks is defined and entry.instructionBlocks ? entry.instructionBlocks.all() : [] %}
	{% macro instructionAsset(asset, className) %}
		{% if asset %}
			{% set localInstructionAsset = asset.url and '/uploads/instructions/' in asset.url %}
			{% set assetUrl = localInstructionAsset ? '/uploads/instructions/' ~ asset.filename : asset.url %}
			<img
				src="{{ assetUrl }}"
				alt="{{ asset.title ?? '' }}"
				class="{{ className }}"
				loading="lazy">
		{% endif %}
	{% endmacro %}
	{% import _self as instructionMacros %}

	<div class="page instruction-page pt-32 lg:pt-[180px]" data-instruction-page>
		<div class="grid grid-cols-12 gap-y-10 lg:gap-x-10">
			<aside class="instruction-page__toc-column col-span-12 lg:col-span-4 self-start">

				<div class="instruction-page__toc-card" data-instruction-toc>
					<h3 class="instruction-page__toc-heading">Contents</h3>
					<ul class="instruction-page__toc-list">
						{% for step in steps %}
							{% set label = step.title ?? ('Step ' ~ loop.index) %}
							{% set anchor = 'step-' ~ loop.index ~ '-' ~ (label|kebab) %}
							{% set subBlocks = step.subBlocks is defined and step.subBlocks ? step.subBlocks.all() : [] %}
							<li class="instruction-page__toc-item{% if subBlocks|length %} has-children{% endif %}" data-instruction-toc-item="{{ anchor }}">
								<a href="#{{ anchor }}" class="instruction-page__toc-link" data-instruction-toc-link="{{ anchor }}">
									<span class="instruction-page__toc-index">{{ loop.index < 10 ? '0' ~ loop.index : loop.index }}</span>
									<span class="instruction-page__toc-label">{{ label }}</span>
									{% if subBlocks|length %}
										<span class="instruction-page__toc-caret" aria-hidden="true"></span>
									{% endif %}
								</a>
								{% if subBlocks|length %}
									<ul class="instruction-page__toc-sublist" data-instruction-toc-sublist>
										{% for subBlock in subBlocks %}
											{% set subLabel = subBlock.title ?? ('subBlock ' ~ loop.index) %}
											{% set subAnchor = anchor ~ '--' ~ loop.index ~ '-' ~ (subLabel|kebab) %}
											<li>
												<a href="#{{ subAnchor }}" class="instruction-page__toc-link instruction-page__toc-sublink" data-instruction-toc-link="{{ subAnchor }}">
													<span class="instruction-page__toc-label">{{ subLabel }}</span>
												</a>
											</li>
										{% endfor %}
									</ul>
								{% endif %}
							</li>
						{% endfor %}
					</ul>
				</div>
			</aside>

			<div class="col-span-12 lg:col-span-8 space-y-8 lg:space-y-10 mb-10 border-b-gray-300 pb-16">
				<h1 class="text-6xl mb-6 border-b-gray-300 border-b pb-4">{{ entry.title }}</h1>
				{% if entry.text is defined and entry.text|length %}
					<div class="grid grid-cols-12">
						{% include '_includes/_blocks/text' with {
								text: entry.text,
								pClass: 'col-span-12 lg:col-span-10'
							} %}
					</div>
				{% endif %}

				{% for step in steps %}
					{% set label = step.title ?? ('Step ' ~ loop.index) %}
					{% set anchor = 'step-' ~ loop.index ~ '-' ~ (label|kebab) %}
					{% set subBlocks = step.subBlocks is defined and step.subBlocks ? step.subBlocks.all() : [] %}
					<section id="{{ anchor }}" class="scroll-mt-32 rounded-xl border border-gray-300 bg-gray-100 p-8 space-y-6" data-instruction-section>
						<div class="flex items-center gap-3 border-b-gray-300 border-b pb-2">
							<span class="text-[0.8rem] tracking-wider uppercase text-gray-500">0{{ loop.index }}</span>
							<h2 class="text-xl lg:text-3xl text-gray-900">{{ label }}</h2>
						</div>
						{% if step.text is defined and step.text|length %}
							{% include '_includes/_blocks/text' with {
								text: step.text,
								pClass: 'col-span-12 lg:col-span-9 text-[16px]'
							} %}
						{% endif %}
						{% if step.asset is defined and step.asset|length %}
							<div class="rounded-xl overflow-hidden w-full border border-gray-300 bg-white mt-4">
								{{ instructionMacros.instructionAsset(step.asset.one(), 'block h-auto w-full') }}
							</div>
						{% endif %}
						{% if subBlocks|length %}
							<div class="mt-4 space-y-4">
								{% for subBlock in subBlocks %}
									{% set subLabel = subBlock.title ?? ('subBlock ' ~ loop.index) %}
									{% set subAnchor = anchor ~ '--' ~ loop.index ~ '-' ~ (subLabel|kebab) %}
									<div id="{{ subAnchor }}" class="scroll-mt-32 rounded-xl border border-gray-300 bg-white p-6 space-y-4" data-instruction-section>
										<div class="flex items-center gap-3 ">
											<h3 class="text-lg text-gray-900">{{ subLabel }}</h3>
										</div>
										{% if subBlock.asset is defined and subBlock.asset|length %}
											<div class="block">
												<div class="rounded-lg overflow-hidden w-full border border-gray-300 bg-gray-50">
													{{ instructionMacros.instructionAsset(subBlock.asset.one(), 'block h-auto w-full') }}
												</div>
											</div>
										{% endif %}

										{% if subBlock.text is defined and subBlock.text|length %}
											{% include '_includes/_blocks/text' with {
												text: subBlock.text,
												pClass: 'col-span-12 lg:col-span-9 text-[16px]',
												ulClass: 'list-disc flex flex-col',
											} %}
										{% endif %}
									</div>
								{% endfor %}
							</div>
						{% endif %}
					</section>
				{% endfor %}
			</div>
		</div>
	</div>
{% endblock %}
