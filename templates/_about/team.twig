{% block content %}
	{% if (entry.heroSlides is defined and entry.heroSlides|length) or entry.asset|length %}
		{% include '_includes/_blocks/bannerHero' with {
            block: entry
        } %}
	{% endif %}

	{% include '_about/profiles' with {
		parent: 'staff',
		contactInfo: true,
		bioInfo: true
	} %}

	<!-- Modal Template -->
	{% include '_includes/_blocks/modalContact' with {
		closeClass: '!stroke-red'
	} %}
{% endblock %}
